redis:
  url: "{{ ha_relayminer_redis_url }}"
  consumer_name: "{{ inventory_hostname }}"
  claim_idle_timeout_ms: 60000

pocket_node:
  query_node_rpc_url: "{{ pocket_rpc_url }}"
  query_node_grpc_url: "{{ pocket_grpc_address }}"
  chain_id: "{{ pocket_chain_id }}"
  grpc_insecure: {{ ha_relayminer_grpc_insecure | bool | lower }}
  query_timeout_seconds: {{ ha_relayminer_query_timeout_seconds }}

keys:
{% if ha_relayminer_keys_mode == 'keys_file' %}
  keys_file: "{{ ha_relayminer_keys_mount_path }}/supplier-keys.yaml"
{% elif ha_relayminer_keys_mode == 'keys_dir' %}
  keys_dir: "{{ ha_relayminer_keys_mount_path }}/suppliers"
{% elif ha_relayminer_keys_mode == 'keyring' %}
  keyring:
    backend: "{{ ha_relayminer_keyring_backend }}"
    dir: "{{ ha_relayminer_keys_mount_path }}/keyring"
    app_name: "{{ ha_relayminer_keyring_app_name }}"
{% if ha_relayminer_key_names | length > 0 %}
    key_names:
{% for key_name in ha_relayminer_key_names %}
      - "{{ key_name }}"
{% endfor %}
{% endif %}
{% endif %}

block_time_seconds: {{ ha_relayminer_block_time_seconds }}

block_health_monitor:
  enabled: true
  slowness_threshold: 1.5

balance_monitor:
  enabled: {{ ha_relayminer_miner_balance_monitor_enabled | bool | lower }}
  check_interval_seconds: 300
  balance_threshold_upokt: {{ ha_relayminer_miner_balance_threshold_upokt }}

session_lifecycle:
  max_concurrent_transitions: 10

leader_election:
  leader_ttl_seconds: 30
  heartbeat_rate_seconds: 10

supplier_claiming:
  claim_ttl_seconds: {{ ha_relayminer_supplier_claim_ttl_seconds }}
  renew_rate_seconds: {{ ha_relayminer_supplier_renew_rate_seconds }}
  rebalance_interval_seconds: {{ ha_relayminer_supplier_rebalance_interval_seconds }}

deduplication_ttl_blocks: 10
batch_size: 1000
ack_batch_size: 50
hot_reload_enabled: true
cache_ttl: "2h"
smst_live_root_checkpoint_interval: 10
submission_tracking_ttl: "168h"
supplier_reconcile_interval_seconds: {{ ha_relayminer_supplier_reconcile_interval_seconds }}

default_service_factor: {{ ha_relayminer_default_service_factor }}

metrics:
  enabled: true
  addr: "{{ ha_relayminer_miner_metrics_addr }}"

pprof:
  enabled: {{ ha_relayminer_pprof_enabled | bool | lower }}
  addr: "{{ ha_relayminer_pprof_addr }}"

logging:
  level: "{{ ha_relayminer_logging_level }}"
  format: "{{ ha_relayminer_logging_format }}"
  output: "stdout"
  async: true
  async_buffer_size: 100000
  enable_caller: false
