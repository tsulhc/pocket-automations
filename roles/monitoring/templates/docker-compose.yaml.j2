services:
  prometheus:
    image: "{{ monitoring_prometheus_image }}"
    container_name: pocket-monitoring-prometheus
    restart: unless-stopped
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time={{ monitoring_prometheus_retention_time }}
      - --web.listen-address=0.0.0.0:9090
    ports:
      - "{{ monitoring_bind_address }}:{{ monitoring_prometheus_port }}:9090"
    volumes:
      - "{{ monitoring_config_dir }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro"
      - "{{ monitoring_data_dir }}/prometheus:/prometheus"

  grafana:
    image: "{{ monitoring_grafana_image }}"
    container_name: pocket-monitoring-grafana
    restart: unless-stopped
    depends_on:
      - prometheus
    environment:
      GF_SECURITY_ADMIN_USER: "{{ monitoring_grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ monitoring_grafana_admin_password }}"
      GF_USERS_ALLOW_SIGN_UP: "{{ monitoring_grafana_allow_signup | bool | lower }}"
      GF_AUTH_ANONYMOUS_ENABLED: "{{ monitoring_grafana_anonymous_enabled | bool | lower }}"
    ports:
      - "{{ monitoring_bind_address }}:{{ monitoring_grafana_port }}:3000"
    volumes:
      - "{{ monitoring_data_dir }}/grafana:/var/lib/grafana"
      - "{{ monitoring_config_dir }}/grafana/provisioning:/etc/grafana/provisioning:ro"
      - "{{ monitoring_config_dir }}/grafana/dashboards:/var/lib/grafana/dashboards:ro"
